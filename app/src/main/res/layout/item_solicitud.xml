<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="#FFFFFF"
    android:elevation="3dp"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/txtNombreSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre del usuario"
        android:textColor="#212121"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtCorreoSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="correo@idat.pe"
        android:textColor="#666666"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtPlacaSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Placa: ABC123"
        android:textColor="#512DA8"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtDetallesSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="4dp"
        android:text="Marca: Toyota"
        android:textColor="#333333"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtFechaSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Fecha"
        android:textColor="#666666"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/txtEstadoItemSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Estado: PENDIENTE"
        android:textColor="#EF6C00"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnAprobarSolicitud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="APROBAR" />

        <Button
            android:id="@+id/btnRechazarSolicitud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="RECHAZAR" />

    </LinearLayout>

</LinearLayout>