<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONTROL DE SEGURIDAD"
            android:textColor="#512DA8"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtBienvenidaSeguridad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Buscar vehículo autorizado"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtPlacaBuscar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Ingrese la placa"
            android:inputType="textCapCharacters"
            android:maxLength="10"
            android:maxLines="1"
            android:padding="14dp" />

        <Button
            android:id="@+id/btnBuscarVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="BUSCAR VEHÍCULO" />

        <TextView
            android:id="@+id/txtMensajeBusqueda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/contenedorResultadoVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtUsuarioVehiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del usuario"
                android:textColor="#212121"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCorreoVehiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="correo@idat.pe"
                android:textColor="#666666"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtPlacaVehiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Placa"
                android:textColor="#512DA8"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDetalleVehiculoSeguridad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtEstadoSolicitudSeguridad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtEstadoMovimientoSeguridad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnRegistrarEntrada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="REGISTRAR ENTRADA"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnRegistrarSalida"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="REGISTRAR SALIDA"
                android:visibility="gone" />

        </LinearLayout>

        <Button
            android:id="@+id/btnCerrarSesionSeguridad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="CERRAR SESIÓN" />

    </LinearLayout>

</ScrollView>